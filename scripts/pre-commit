#!/bin/bash
# Pre-commit hook for Coax
# This hook scans staged files for secrets before allowing a commit

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}🔍${NC} ${BLUE}Coax pre-commit scan...${NC}"

# Get staged files (only added, copied, modified files)
FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")

if [ -z "$FILES" ]; then
    echo -e "${GREEN}✅${NC} No staged files to scan"
    exit 0
fi

# Check if coax is available
if ! command -v coax &> /dev/null; then
    echo -e "${RED}❌${NC} coax command not found. Please install coax first."
    echo "   Install with: cargo install --path ."
    exit 1
fi

# Create temporary file list
TEMP_FILE=$(mktemp)
echo "$FILES" > "$TEMP_FILE"

# Check for .coaxignore file
COAXIGNORE_ARGS=""
if [ -f ".coaxignore" ]; then
    echo -e "${YELLOW}ℹ️${NC} Using .coaxignore for exclusions"
fi

# Scan staged files
echo -e "${BLUE}📄${NC} Scanning ${YELLOW}$(echo "$FILES" | wc -l | tr -d ' ')${NC} staged files..."

# Build the list of files to scan
FILES_TO_SCAN=""
for file in $FILES; do
    if [ -f "$file" ]; then
        FILES_TO_SCAN="$FILES_TO_SCAN $file"
    fi
done

if [ -z "$FILES_TO_SCAN" ]; then
    echo -e "${GREEN}✅${NC} No files to scan"
    rm -f "$TEMP_FILE"
    exit 0
fi

# Run coax scan on staged files
# Using --baseline if it exists
BASELINE_ARGS=""
if [ -f ".coax-baseline.json" ]; then
    BASELINE_ARGS="--baseline .coax-baseline.json"
    echo -e "${YELLOW}ℹ️${NC} Using baseline file for comparison"
fi

# Run the scan
SCAN_OUTPUT=$(coax scan secrets -p . $BASELINE_ARGS 2>&1) || SCAN_EXIT_CODE=$?

rm -f "$TEMP_FILE"

if [ "${SCAN_EXIT_CODE:-0}" -ne 0 ]; then
    echo ""
    echo -e "${RED}❌${NC} ${RED}Secrets detected! Commit blocked.${NC}"
    echo ""
    echo "$SCAN_OUTPUT"
    echo ""
    echo -e "${YELLOW}⚠️${NC} To fix this:"
    echo "   1. Remove the secrets from your code"
    echo "   2. Add false positives to .coaxignore"
    echo "   3. Generate a baseline with: coax baseline --generate"
    echo ""
    echo -e "${YELLOW}⚠️${NC} If this is a false positive, you can bypass with:"
    echo "   ${BLUE}git commit --no-verify${NC}"
    echo ""
    exit 1
fi

echo -e "${GREEN}✅${NC} ${GREEN}No secrets found${NC}"
exit 0
